{
  "rules": {
    ".read": false,
    ".write": false,
    "iot_readings": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.role === 'admin' || auth.token.role === 'agricultural_officer'",
        "$deviceId": {
          ".write": "$uid === auth.uid || auth.token.role === 'admin'",
          ".validate": "newData.hasChildren(['timestamp'])",
          "timestamp": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": true }
        }
      }
    },
    "sensor_readings": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.role === 'admin' || auth.token.role === 'agricultural_officer'",
        ".write": "$uid === auth.uid || auth.token.role === 'admin'",
        ".indexOn": ["timestamp", "deviceId"]
      }
    }
  }
}
