rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function admin() {
      return signedIn() && request.auth.token.role in ['admin', 'administrator'];
    }
    function imageOrDocument() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType in ['application/pdf', 'text/csv'];
    }

    match /users/{uid}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());
      allow write: if signedIn() && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024
                   && imageOrDocument();
    }
    match /detections/{uid}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());
      allow write: if signedIn() && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /reports/{uid}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());
      allow write: if signedIn() && request.auth.uid == uid
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType in ['application/pdf', 'text/csv'];
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
